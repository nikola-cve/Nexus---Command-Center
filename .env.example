# Nexus Command Center environment variables
# Copy this file to .env.local and fill in the values. Never commit real secrets.

# Claude engine (added in Step 3). Pay-as-you-go API key, not a Max/Pro subscription.
ANTHROPIC_API_KEY=

# Supabase (added in Step 2). Get these from the Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side Postgres connection string for Drizzle (keep secret).
DATABASE_URL=
